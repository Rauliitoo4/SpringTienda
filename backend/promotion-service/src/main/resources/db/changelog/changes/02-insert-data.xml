    <changeSet id="05-insert-promociones-productos" author="raul.redondochicano">
        <insert tableName="producto_promocion">
            <column name="product_id" valueNumeric="1"/>
            <column name="promotion_id" valueNumeric="1"/>
        </insert>
        <insert tableName="producto_promocion">
            <column name="product_id" valueNumeric="3"/>
            <column name="promotion_id" valueNumeric="1"/>
        </insert>
        <insert tableName="producto_promocion">
            <column name="product_id" valueNumeric="2"/>
            <column name="promotion_id" valueNumeric="1"/>
        </insert>
        <insert tableName="producto_promocion">
            <column name="product_id" valueNumeric="19"/>
            <column name="promotion_id" valueNumeric="1"/>
        </insert>
        <insert tableName="producto_promocion">
            <column name="product_id" valueNumeric="4"/>
            <column name="promotion_id" valueNumeric="2"/>
        </insert>
        <insert tableName="producto_promocion">
            <column name="product_id" valueNumeric="9"/>
            <column name="promotion_id" valueNumeric="2"/>
        </insert>
        <insert tableName="producto_promocion">
            <column name="product_id" valueNumeric="18"/>
            <column name="promotion_id" valueNumeric="2"/>
        </insert>
        <insert tableName="producto_promocion">
            <column name="product_id" valueNumeric="20"/>
            <column name="promotion_id" valueNumeric="2"/>
        </insert>

        <update tableName="productos">
            <column name="final_price" valueComputed="ROUND(CAST(price * 0.9 AS NUMERIC), 2)"/>
            <where>id IN (1, 3, 2, 19)</where>
        </update>

        <update tableName="productos">
            <column name="final_price" valueComputed="ROUND(CAST(price * 0.8 AS NUMERIC), 2)"/>
            <where>id IN (4, 9, 18, 20)</where>
        </update>
    </changeSet>

</databaseChangeLog>