<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog 
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="01-create-table-promociones" author="raul.redondochicano">
        <createTable tableName="promociones">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="descripcion" type="VARCHAR(255)"/>
            <column name="descuento" type="DOUBLE PRECISION"/>
        </createTable>
    </changeSet>

    <changeSet id="01-create-table-productos" author="raul.redondochicano">
        <createTable tableName="productos">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre" type="VARCHAR(255)"/>
            <column name="precio" type="DOUBLE PRECISION"/>
            <column name="precio_final" type="DOUBLE PRECISION"/>
            <column name="descripcion" type="VARCHAR(255)"/>
            <column name="material" type="VARCHAR(255)"/>
            <column name="consideraciones" type="VARCHAR(255)"/>
            <column name="imagen_url" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="01-create-table-producto-promocion" author="raul.redondochicano">
        <createTable tableName="producto_promocion">
            <column name="producto_id" type="INT">
                <constraints nullable="false" foreignKeyName="fk_producto" references="productos(id)"/>
            </column>
            <column name="promocion_id" type="INT">
                <constraints nullable="false" foreignKeyName="fk_promocion" references="promociones(id)"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="01-create-table-carritos" author="raul.redondochicano">
        <createTable tableName="carritos">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="total" type="DOUBLE PRECISION"/>
        </createTable>
    </changeSet>

    <changeSet id="01-create-table-usuarios" author="raul.redondochicano">
        <createTable tableName="usuarios">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre" type="VARCHAR(255)"/>
            <column name="apellidos" type="VARCHAR(255)"/>
            <column name="username" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="password" type="VARCHAR(255)"/>
            <column name="carrito_id" type="INT">
                <constraints nullable="false" foreignKeyName="fk_carrito" references="carritos(id)"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="01-create-table-lineas-carrito" author="raul.redondochicano">
        <createTable tableName="lineas_carrito">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="subtotal" type="DOUBLE PRECISION"/>
            <column name="cantidad" type="DOUBLE PRECISION"/>
            <column name="product_id" type="INT">
                <constraints nullable="false" foreignKeyName="fk_linea_producto" references="productos(id)"/>
            </column>
            <column name="carrito_id" type="INT">
                <constraints nullable="false" foreignKeyName="fk_linea_carrito" references="carritos(id)"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>

