<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog 
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="01-create-table-promociones" author="raul.redondochicano">
        <createTable tableName="promociones">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="discount" type="DOUBLE PRECISION"/>
        </createTable>
    </changeSet>

    <changeSet id="01-create-table-productos" author="raul.redondochicano">
        <createTable tableName="productos">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="price" type="DOUBLE PRECISION"/>
            <column name="final_price" type="DOUBLE PRECISION"/>
            <column name="description" type="VARCHAR(255)"/>
            <column name="material" type="VARCHAR(255)"/>
            <column name="considerations" type="VARCHAR(255)"/>
            <column name="image_url" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="01-create-table-producto-promocion" author="raul.redondochicano">
        <createTable tableName="producto_promocion">
            <column name="product_id" type="INT">
                <constraints nullable="false" foreignKeyName="fk_product" references="productos(id)"/>
            </column>
            <column name="promotion_id" type="INT">
                <constraints nullable="false" foreignKeyName="fk_promotion" references="promociones(id)"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="01-create-table-carritos" author="raul.redondochicano">
        <createTable tableName="carritos">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="total" type="DOUBLE PRECISION"/>
        </createTable>
    </changeSet>

    <changeSet id="01-create-table-usuarios" author="raul.redondochicano">
        <createTable tableName="usuarios">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="lastname" type="VARCHAR(255)"/>
            <column name="username" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="password" type="VARCHAR(255)"/>
            <column name="carrito_id" type="INT">
                <constraints nullable="false" foreignKeyName="fk_carrito" references="carritos(id)"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="01-create-table-lineas-carrito" author="raul.redondochicano">
        <createTable tableName="lineas_carrito">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="subtotal" type="DOUBLE PRECISION"/>
            <column name="quantity" type="INT"/>
            <column name="product_id" type="INT">
                <constraints nullable="false" foreignKeyName="fk_linea_producto" references="productos(id)"/>
            </column>
            <column name="carrito_id" type="INT">
                <constraints nullable="false" foreignKeyName="fk_linea_carrito" references="carritos(id)"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="01-add-pk-to-producto-promocion" author="raul.redondochicano">
        <addPrimaryKey tableName="producto_promocion"
                       columnNames="product_id, promotion_id"/>
    </changeSet>


</databaseChangeLog>

