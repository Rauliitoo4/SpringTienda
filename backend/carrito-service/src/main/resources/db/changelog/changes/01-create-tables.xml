<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="01-create-table-carritos" author="raul.redondochicano">
        <createTable tableName="carritos">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="total" type="DOUBLE PRECISION"/>
        </createTable>
    </changeSet>

    <changeSet id="02-create-table-lineas-carrito" author="raul.redondochicano">
        <createTable tableName="lineas_carrito">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="subtotal" type="DOUBLE PRECISION"/>
            <column name="quantity" type="INTEGER"/>
            <column name="size" type="VARCHAR(50)"/>
            <column name="carrito_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="product_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>