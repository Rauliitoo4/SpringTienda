<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="01-create-table-productos" author="raul.redondochicano">
        <createTable tableName="productos">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="price" type="DOUBLE PRECISION"/>
            <column name="final_price" type="DOUBLE PRECISION"/>
            <column name="description" type="VARCHAR(255)"/>
            <column name="material" type="VARCHAR(255)"/>
            <column name="considerations" type="VARCHAR(255)"/>
            <column name="image_url" type="VARCHAR(255)"/>
            <column name="category" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>
    </changeSet>

    <changeSet id="02-create-table-producto_promocion" author="raul.redondochicano">
        <createTable tableName="producto_promocion">
            <column name="product_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="promotion_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>